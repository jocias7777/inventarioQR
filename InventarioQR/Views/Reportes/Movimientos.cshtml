@using X.PagedList
@model X.PagedList.IPagedList<InventarioQR.ViewModels.ReporteMovimientoDto>
@{
    ViewData["Title"] = "Reporte Movimientos";
    ViewData["Section"] = "Reportes";

    string tipo = ViewBag.Tipo as string ?? string.Empty;
    string fechaDesde = ViewBag.FechaDesde as string ?? string.Empty;
    string fechaHasta = ViewBag.FechaHasta as string ?? string.Empty;
}

<div class="page-header">
    <div>
        <div class="page-title">Reporte Movimientos</div>
        <div class="page-subtitle">
            Historial operacional Ś @Model.TotalItemCount registro(s)
        </div>
    </div>
    <div style="display:flex;gap:8px;align-items:center;">
        <a href="/Reportes" class="btn-secondary-app">
            <i class="bi bi-arrow-left"></i> Reportes
        </a>
        @if (User.IsInRole("Administrador"))
        {
            <a href="/Reportes/ExportarMovimientos?tipo=@tipo&fechaDesde=@fechaDesde&fechaHasta=@fechaHasta"
               class="btn-primary-app">
                <i class="bi bi-file-earmark-excel"></i> Excel
            </a>
        }
    </div>
</div>

<div class="card" style="margin-bottom:16px;">
    <div class="card-body" style="padding:14px 20px;">
        <form method="get" style="display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap;">
            <div>
                <label style="display:block;font-size:.75rem;color:var(--color-text-muted);margin-bottom:4px;">Tipo</label>
                <select name="tipo" class="form-select" style="min-width:170px;">
                    <option value="">Todos</option>
                    <option value="Entrada" selected="@(tipo == "Entrada")">Entradas</option>
                    <option value="Salida" selected="@(tipo == "Salida")">Salidas</option>
                    <option value="Transferencia" selected="@(tipo == "Transferencia")">Transferencias</option>
                    <option value="Ajuste" selected="@(tipo == "Ajuste")">Ajustes</option>
                </select>
            </div>

            <div>
                <label style="display:block;font-size:.75rem;color:var(--color-text-muted);margin-bottom:4px;">Desde</label>
                <input type="date" name="fechaDesde" value="@fechaDesde" class="form-control" />
            </div>

            <div>
                <label style="display:block;font-size:.75rem;color:var(--color-text-muted);margin-bottom:4px;">Hasta</label>
                <input type="date" name="fechaHasta" value="@fechaHasta" class="form-control" />
            </div>

            <button type="submit" class="btn-secondary-app">
                <i class="bi bi-funnel"></i> Filtrar
            </button>

            <a href="/Reportes/Movimientos" class="btn-secondary-app">
                Limpiar
            </a>
        </form>
    </div>
</div>

<div class="card">
    <div class="table-wrapper">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-arrow-left-right"></i>
                <p>No hay movimientos para los filtros seleccionados.</p>
            </div>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Tipo</th>
                        <th>Producto</th>
                        <th>Origen</th>
                        <th>Destino</th>
                        <th>Cant.</th>
                        <th>Usuario</th>
                        <th>Fecha</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model)
                    {
                        var badge = m.Tipo switch
                        {
                            "Entrada" => "badge-activo",
                            "Salida" => "badge-critico",
                            "Transferencia" => "badge-transito",
                            _ => "badge-alerta"
                        };

                        <tr>
                            <td style="font-size:.75rem;color:var(--color-text-muted);">#@m.Id</td>
                            <td><span class="badge-status @badge">@m.Tipo</span></td>
                            <td>
                                <div style="font-weight:500;font-size:.875rem;">@m.ProductoNombre</div>
                                <div style="font-size:.75rem;font-family:monospace;color:var(--color-text-muted);">
                                    @m.ProductoSKU
                                </div>
                            </td>
                            <td style="max-width:170px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="@m.UbicacionOrigen">
                                @(m.UbicacionOrigen ?? "Ś")
                            </td>
                            <td style="max-width:170px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="@m.UbicacionDestino">
                                @(m.UbicacionDestino ?? "Ś")
                            </td>
                            <td style="font-weight:700;">@m.Cantidad</td>
                            <td style="font-size:.8125rem;color:var(--color-text-secondary);">@m.NombreUsuario</td>
                            <td style="font-size:.8125rem;white-space:nowrap;">
                                @m.FechaHora.ToString("dd/MM/yyyy HH:mm")
                            </td>
                        </tr>
                        @if (!string.IsNullOrWhiteSpace(m.Motivo))
                        {
                            <tr>
                                <td></td>
                                <td colspan="7" style="font-size:.8125rem;color:var(--color-text-muted);padding-top:0;">
                                    <i class="bi bi-chat-left-text"></i> @m.Motivo
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

            @if (Model.PageCount > 1)
            {
                <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-top:1px solid var(--color-border);">
                    <span style="font-size:.8125rem;color:var(--color-text-muted);">
                        Pßgina @Model.PageNumber de @Model.PageCount
                    </span>
                    <div style="display:flex;gap:4px;">
                        @if (Model.HasPreviousPage)
                        {
                            <a href="?pagina=@(Model.PageNumber - 1)&tipo=@tipo&fechaDesde=@fechaDesde&fechaHasta=@fechaHasta"
                               class="btn-secondary-app" style="padding:5px 10px;">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        }
                        @if (Model.HasNextPage)
                        {
                            <a href="?pagina=@(Model.PageNumber + 1)&tipo=@tipo&fechaDesde=@fechaDesde&fechaHasta=@fechaHasta"
                               class="btn-secondary-app" style="padding:5px 10px;">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>
