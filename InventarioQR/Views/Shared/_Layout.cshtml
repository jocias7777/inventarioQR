@using Microsoft.AspNetCore.Identity
@inject SignInManager<InventarioQR.Models.Entities.ApplicationUser> SignInManager
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — InventarioQR</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/app.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="app-wrapper">

        @if (SignInManager.IsSignedIn(User))
        {
            @await Html.PartialAsync("_Sidebar")
        }

        <div class="main-content" id="mainContent">

            @if (SignInManager.IsSignedIn(User))
            {
                @await Html.PartialAsync("_Header")
            }

            <!-- TempData alerts -->
            @if (TempData["Success"] != null)
            {
                <div class="alert-app" style="background:#f0fdf4;border-left:3px solid #16a34a;color:#166534;margin-bottom:20px;">
                    <i class="bi bi-check-circle-fill"></i>
                    <span>@TempData["Success"]</span>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert-app danger" style="margin-bottom:20px;">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <span>@TempData["Error"]</span>
                </div>
            }

            @{
                var deleteSuccess = TempData["DeleteSuccess"] as string;
            }
            @if (!string.IsNullOrWhiteSpace(deleteSuccess))
            {
                <div id="deleteSuccessModal" class="delete-success-overlay">
                    <div class="delete-success-box">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>@deleteSuccess</span>
                    </div>
                </div>
            }

            @{
                var createSuccess = TempData["CreateSuccess"] as string;
            }
            @if (!string.IsNullOrWhiteSpace(createSuccess))
            {
                <div id="createSuccessModal" class="delete-success-overlay">
                    <div class="delete-success-box">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>@createSuccess</span>
                    </div>
                </div>
            }

            @{
                var updateSuccess = TempData["UpdateSuccess"] as string;
            }
            @if (!string.IsNullOrWhiteSpace(updateSuccess))
            {
                <div id="updateSuccessModal" class="delete-success-overlay">
                    <div class="delete-success-box">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>@updateSuccess</span>
                    </div>
                </div>
            }

            @RenderBody()
        </div>
    </div>

    <!-- ── Modal de confirmación global ── -->
    <div id="confirmModal" class="confirm-overlay" style="display:none;">
        <div class="confirm-box">
            <div class="confirm-icon">?</div>
            <div class="confirm-title">¿Desea continuar?</div>
            <div class="confirm-msg" id="confirmMsg"></div>
            <div class="confirm-actions">
                <a id="confirmBtn" href="#" class="btn-success-app">
                    Sí, continuar
                </a>
                <button onclick="cerrarConfirm()" class="btn-secondary-app">
                    Cancelar
                </button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/app.js"></script>

    <script>
        let pendingConfirmForm = null;

        function confirmDelete(url, mensaje) {
            pendingConfirmForm = null;
            document.getElementById('confirmMsg').textContent = mensaje;
            document.getElementById('confirmBtn').href = url;
            document.getElementById('confirmModal').style.display = 'flex';
        }

        function confirmPost(form, mensaje) {
            if (!form) return false;
            pendingConfirmForm = form;
            document.getElementById('confirmMsg').textContent = mensaje;
            document.getElementById('confirmBtn').href = '#';
            document.getElementById('confirmModal').style.display = 'flex';
            return false;
        }

        function cerrarConfirm() {
            document.getElementById('confirmModal').style.display = 'none';
        }

        document.getElementById('confirmModal').addEventListener('click', function (e) {
            if (e.target === this) cerrarConfirm();
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') cerrarConfirm();
        });

        document.getElementById('confirmBtn').addEventListener('click', function (e) {
            if (pendingConfirmForm) {
                e.preventDefault();
                const form = pendingConfirmForm;
                pendingConfirmForm = null;
                cerrarConfirm();
                form.submit();
            }
        });

    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>