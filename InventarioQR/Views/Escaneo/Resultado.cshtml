@model InventarioQR.ViewModels.EscaneoResultadoDto
@{
    ViewData["Title"] = "Resultado del escaneo";
    ViewData["Section"] = "Portal Escaneo";
    Layout = "_Layout";
}

<div style="max-width:580px;margin:0 auto;">

    <!-- Botón volver -->
    <a href="/Escaneo"
       class="btn-secondary-app"
       style="margin-bottom:20px;display:inline-flex;">
        <i class="bi bi-arrow-left"></i> Nuevo escaneo
    </a>

    @if (!Model.Encontrado)
    {
        <!-- Error -->
        <div class="card" style="text-align:center;padding:48px 24px;">
            <i class="bi bi-qr-code"
               style="font-size:3rem;color:var(--color-danger);
                          display:block;margin-bottom:16px;"></i>
            <h2 style="font-size:1.125rem;font-weight:700;
                           margin-bottom:8px;">
                QR no reconocido
            </h2>
            <p style="color:var(--color-text-secondary);
                          font-size:.9375rem;">
                @Model.Error
            </p>
            <a href="/Escaneo"
               class="btn-primary-app"
               style="margin-top:20px;display:inline-flex;">
                Intentar de nuevo
            </a>
        </div>
    }
    else
    {
        <!-- Tarjeta principal del producto -->
        <div class="card" style="margin-bottom:16px;">
            <div style="padding:20px;">
                <div style="display:flex;align-items:flex-start;gap:16px;">

                    <!-- Imagen -->
                    @if (!string.IsNullOrEmpty(Model.ProductoImagenUrl))
                    {
                        <img src="@Model.ProductoImagenUrl"
                             alt="@Model.ProductoNombre"
                             style="width:72px;height:72px;object-fit:cover;
                                            border-radius:var(--radius);flex-shrink:0;
                                            border:1px solid var(--color-border);" />
                    }
                    else
                    {
                        <div style="width:72px;height:72px;
                                            background:var(--color-border-light);
                                            border-radius:var(--radius);flex-shrink:0;
                                            display:flex;align-items:center;
                                            justify-content:center;">
                            <i class="bi bi-box"
                               style="font-size:1.75rem;
                                              color:var(--color-text-muted);"></i>
                        </div>
                    }

                    <!-- Datos principales -->
                    <div style="flex:1;min-width:0;">
                        <div style="display:flex;align-items:center;
                                        gap:8px;margin-bottom:4px;flex-wrap:wrap;">
                            <h2 style="font-size:1.0625rem;font-weight:700;
                                           margin:0;">
                                @Model.ProductoNombre
                            </h2>
                            <span class="badge-status @(Model.EstadoProducto == "Activo"
                                                                  ? "badge-activo" : "badge-inactivo")">
                            @Model.EstadoProducto
                        </span>
                    </div>
                    <div style="font-family:monospace;font-size:.8125rem;
                                    color:var(--color-text-muted);margin-bottom:8px;">
                        @Model.ProductoSKU
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Descripcion))
                        {
                            <p style="font-size:.875rem;
                                              color:var(--color-text-secondary);
                                              margin:0;line-height:1.5;">
                                @Model.Descripcion
                            </p>
                        }
                        <div style="margin-top:8px;font-size:.9375rem;
                                        font-weight:700;">
                            Q @Model.PrecioBase.ToString("N2")
                        </div>
                    </div>
                </div>
            </div>

            <!-- Ubicación exacta -->
            <div style="padding:14px 20px;
                            border-top:1px solid var(--color-border);
                            background:var(--color-border-light);
                            display:flex;align-items:center;gap:10px;">
                <i class="bi bi-geo-alt-fill"
                   style="color:var(--color-accent);font-size:1rem;
                              flex-shrink:0;"></i>
                <div>
                    <div style="font-size:.6875rem;font-weight:600;
                                    text-transform:uppercase;letter-spacing:.08em;
                                    color:var(--color-text-muted);">
                        Ubicación exacta
                    </div>
                    <div style="font-size:.875rem;font-weight:500;">
                        @Model.Ubicacion
                    </div>
                </div>
            </div>
        </div>

        <!-- Stock -->
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;
                        gap:12px;margin-bottom:16px;">

            <div class="card" style="padding:16px;text-align:center;">
                <div style="font-size:1.625rem;font-weight:700;
                        color:@(Model.StockEnUbicacion == 0
                                             ? "var(--color-danger)"
                                             : Model.StockEnUbicacion < 5
                                                 ? "var(--color-warning)"
                                                 : "var(--color-success)");">
                @Model.StockEnUbicacion
            </div>
            <div style="font-size:.6875rem;
                            color:var(--color-text-secondary);
                            margin-top:4px;font-weight:500;">
                En esta ubicación
            </div>
        </div>

            <div class="card" style="padding:16px;text-align:center;">
                <div style="font-size:1.625rem;font-weight:700;
                                color:var(--color-accent);">
                    @Model.StockGlobal
                </div>
                <div style="font-size:.6875rem;
                                color:var(--color-text-secondary);
                                margin-top:4px;font-weight:500;">
                    Stock global
                </div>
            </div>

            <div class="card" style="padding:16px;text-align:center;">
                <div style="font-size:1.625rem;font-weight:700;
                                color:var(--color-warning);">
                    @Model.StockReservado
                </div>
                <div style="font-size:.6875rem;
                                color:var(--color-text-secondary);
                                margin-top:4px;font-weight:500;">
                    Reservado
                </div>
            </div>

        </div>

        <!-- Acciones rápidas -->
        <div class="card" style="margin-bottom:16px;">
            <div class="card-header">
                <span class="card-title">Acciones rápidas</span>
            </div>
            <div class="card-body"
                 style="display:flex;flex-direction:column;gap:8px;">

                <button class="btn-primary-app"
                        style="justify-content:center;"
                        data-bs-toggle="modal"
                        data-bs-target="#modalReservar">
                    <i class="bi bi-bookmark-plus"></i>
                    Reservar unidades
                </button>

                <a href="/Movimientos/Registrar?productoId=@Model.ProductoId"
                   class="btn-secondary-app"
                   style="justify-content:center;">
                    <i class="bi bi-arrow-left-right"></i>
                    Registrar movimiento
                </a>

                <button class="btn-secondary-app"
                        style="justify-content:center;
                                   color:var(--color-warning);
                                   border-color:var(--color-warning);"
                        data-bs-toggle="modal"
                        data-bs-target="#modalReporte">
                    <i class="bi bi-flag"></i>
                    Reportar problema
                </button>

            </div>
        </div>

        <!-- Otras ubicaciones -->
    @if (Model.OtrasUbicaciones.Any())
        {
            <div class="card" style="margin-bottom:16px;">
                <div class="card-header">
                    <span class="card-title">
                        <i class="bi bi-geo me-2"></i>
                        Otras ubicaciones con stock
                    </span>
                </div>
                @foreach (var u in Model.OtrasUbicaciones)
                {
                    <div style="display:flex;align-items:center;
                                            justify-content:space-between;
                                            padding:11px 20px;
                                            border-bottom:1px solid var(--color-border-light);">
                        <div style="font-size:.875rem;
                                                color:var(--color-text-secondary);">
                            @u.Ubicacion
                        </div>
                        <span style="font-weight:700;
                                                 color:var(--color-success);
                                                 font-size:.9375rem;">
                            @u.Disponible uds
                        </span>
                    </div>
                }
            </div>
        }
    }
</div>

<!-- ══════════════════════
     MODAL: Reservar
     ══════════════════════ -->
@if (Model.Encontrado)
{
    <div class="modal fade" id="modalReservar" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered"
             style="margin-top:60px;max-width:420px;">
            <div class="modal-content"
                 style="border-radius:var(--radius);
                            border:1px solid var(--color-border);">
                <div class="modal-header"
                     style="border-bottom:1px solid var(--color-border);
                                padding:16px 20px;">
                    <h6 class="modal-title fw-bold">
                        <i class="bi bi-bookmark-plus me-2"
                           style="color:var(--color-warning);"></i>
                        Reservar — @Model.ProductoNombre
                    </h6>
                    <button type="button" class="btn-close btn-close-sm"
                            data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" style="padding:20px;">
                    <div style="background:var(--color-border-light);
                                    border-radius:var(--radius);
                                    padding:12px 14px;margin-bottom:16px;
                                    font-size:.875rem;">
                        <div style="display:flex;justify-content:space-between;">
                            <span style="color:var(--color-text-secondary);">
                                Disponible en ubicación
                            </span>
                            <span style="font-weight:700;
                                             color:var(--color-success);">
                                @Model.StockEnUbicacion uds
                            </span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"
                               style="font-size:.8125rem;font-weight:500;">
                            Cantidad a reservar *
                        </label>
                        <input type="number" id="cantReserva"
                               min="1" max="@Model.StockEnUbicacion"
                               value="1"
                               class="form-control"
                               style="border-radius:var(--radius);
                                          font-size:1.25rem;font-weight:700;
                                          text-align:center;" />
                    </div>
                    <div class="mb-0">
                        <label class="form-label"
                               style="font-size:.8125rem;font-weight:500;">
                            Referencia / Motivo
                        </label>
                        <input type="text" id="motivoReserva"
                               class="form-control"
                               style="border-radius:var(--radius);"
                               placeholder="Ej: Orden #1234" />
                    </div>
                </div>
                <div class="modal-footer"
                     style="border-top:1px solid var(--color-border);
                                padding:12px 20px;">
                    <button type="button" class="btn-secondary-app"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="button" class="btn-primary-app"
                            onclick="confirmarReserva()">
                        <i class="bi bi-bookmark-check"></i> Confirmar reserva
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL: Reportar problema -->
    <div class="modal fade" id="modalReporte" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered"
             style="margin-top:60px;max-width:420px;">
            <div class="modal-content"
                 style="border-radius:var(--radius);
                            border:1px solid var(--color-border);">
                <div class="modal-header"
                     style="border-bottom:1px solid var(--color-border);
                                padding:16px 20px;">
                    <h6 class="modal-title fw-bold">
                        <i class="bi bi-flag me-2"
                           style="color:var(--color-warning);"></i>
                        Reportar problema
                    </h6>
                    <button type="button" class="btn-close btn-close-sm"
                            data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" style="padding:20px;">
                    <div class="mb-3">
                        <label class="form-label"
                               style="font-size:.8125rem;font-weight:500;">
                            Tipo de problema
                        </label>
                        <select id="tipoProblema" class="form-select"
                                style="border-radius:var(--radius);font-size:.875rem;">
                            <option value="stock">Stock físico incorrecto</option>
                            <option value="ubicacion">Producto en ubicación incorrecta</option>
                            <option value="dañado">Producto dañado</option>
                            <option value="otro">Otro</option>
                        </select>
                    </div>
                    <div class="mb-0">
                        <label class="form-label"
                               style="font-size:.8125rem;font-weight:500;">
                            Descripción
                        </label>
                        <textarea id="descProblema" class="form-control"
                              rows="3"
                              style="border-radius:var(--radius);resize:none;"
                              placeholder="Describe el problema..."></textarea>
                    </div>
                </div>
                <div class="modal-footer"
                     style="border-top:1px solid var(--color-border);
                                padding:12px 20px;">
                    <button type="button" class="btn-secondary-app"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="button" class="btn-primary-app"
                            style="background:var(--color-warning);color:#fff;"
                            onclick="enviarReporte()">
                        <i class="bi bi-flag-fill"></i> Enviar reporte
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        async function confirmarReserva() {
            const cant = parseInt(document.getElementById('cantReserva').value);
            const max  = @(Model.Encontrado? Model.StockEnUbicacion: 0);

            if (cant < 1 || cant > max) {
                alert(`La cantidad debe estar entre 1 y ${max}`);
                return;
            }

            const res = await fetch('/Escaneo/ReservarRapido', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    productoId: @(Model.Encontrado? Model.ProductoId: 0),
                    posicionId: 0,
                    cantidad: cant
                })
            });

            const data = await res.json();
            bootstrap.Modal.getInstance(
                document.getElementById('modalReservar'))?.hide();
            alert(data.msg);
        }

        async function enviarReporte() {
            const tipo = document.getElementById('tipoProblema').value;
            const desc = document.getElementById('descProblema').value;

            if (!desc.trim()) {
                alert('Escribe una descripción del problema.');
                return;
            }

            // Por ahora muestra confirmación (se conecta al módulo de auditoría)
            bootstrap.Modal.getInstance(
                document.getElementById('modalReporte'))?.hide();
            alert('Reporte enviado. El equipo de bodega será notificado.');
        }
    </script>
}