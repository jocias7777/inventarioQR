@model InventarioQR.ViewModels.ProductoDetalleDto

<!-- Imagen -->
@if (!string.IsNullOrEmpty(Model.ImagenUrl))
{
    <img src="@Model.ImagenUrl" alt="@Model.Nombre"
         style="width:100%;height:160px;object-fit:cover;border-radius:var(--radius);
                    margin-bottom:16px;border:1px solid var(--color-border);" />
}

<!-- Info principal -->
<div style="margin-bottom:16px;">
    <div style="font-size:1rem;font-weight:700;margin-bottom:2px;">@Model.Nombre</div>
    <div style="font-family:monospace;font-size:.8125rem;
                color:var(--color-text-muted);">
        @Model.SKU
    </div>
</div>

<!-- Stats rápidos -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px;">
    <div style="background:var(--color-success-light);border-radius:var(--radius);
                padding:10px;text-align:center;">
        <div style="font-size:1.25rem;font-weight:700;
                    color:var(--color-success);">
            @Model.StockTotal
        </div>
        <div style="font-size:.6875rem;color:var(--color-success);">Disponible</div>
    </div>
    <div style="background:var(--color-warning-light);border-radius:var(--radius);
                padding:10px;text-align:center;">
        <div style="font-size:1.25rem;font-weight:700;
                    color:var(--color-warning);">
            @Model.StockReservado
        </div>
        <div style="font-size:.6875rem;color:var(--color-warning);">Reservado</div>
    </div>
</div>

<!-- Detalles -->
<div style="margin-bottom:16px;">
    <div style="font-size:.6875rem;font-weight:600;text-transform:uppercase;
                letter-spacing:.08em;color:var(--color-text-muted);margin-bottom:8px;">
        Información
    </div>
    <div style="font-size:.875rem;display:flex;flex-direction:column;gap:6px;">
        <div style="display:flex;justify-content:space-between;">
            <span style="color:var(--color-text-secondary);">Precio base</span>
            <span style="font-weight:500;">Q @Model.PrecioBase.ToString("N2")</span>
        </div>
        <div style="display:flex;justify-content:space-between;">
            <span style="color:var(--color-text-secondary);">Estado</span>
            @{
                var estadoColor = Model.Estado == "Activo"
                    ? "var(--color-success)"
                    : "var(--color-text-muted)";
            }
            <span style="display:inline-flex;align-items:center;padding:4px 10px;
                         font-size:.75rem;font-weight:600;line-height:1;
                         border:1px solid @estadoColor;background:@estadoColor;
                         color:#fff;border-radius:var(--radius);">
                @Model.Estado
            </span>
        </div>
        @if (!string.IsNullOrEmpty(Model.Descripcion))
        {
            <div style="margin-top:4px;color:var(--color-text-secondary);
                            font-size:.8125rem;line-height:1.5;">
                @Model.Descripcion
            </div>
        }
    </div>
</div>

<!-- Variantes -->
@if (Model.Variantes.Any())
{
    <div style="margin-bottom:16px;">
        <div style="font-size:.6875rem;font-weight:600;text-transform:uppercase;
                        letter-spacing:.08em;color:var(--color-text-muted);margin-bottom:8px;">
            Variantes (@Model.Variantes.Count)
        </div>
        @foreach (var v in Model.Variantes)
        {
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
                <div style="width:14px;height:14px;border-radius:50%;
                                    background:@v.Color;border:1px solid var(--color-border);
                                    flex-shrink:0;"></div>
                <span style="font-size:.8125rem;">@v.Color / @v.Tamaño</span>
                <span style="font-size:.75rem;font-family:monospace;
                                     color:var(--color-text-muted);margin-left:auto;">
                    @v.SKUVariante
                </span>
            </div>
        }
    </div>
}

<!-- Ubicaciones -->
@if (Model.Ubicaciones.Any())
{
    <div>
        <div style="font-size:.6875rem;font-weight:600;text-transform:uppercase;
                        letter-spacing:.08em;color:var(--color-text-muted);margin-bottom:8px;">
            Ubicaciones con stock
        </div>
        @foreach (var u in Model.Ubicaciones)
        {
            <div style="background:var(--color-border-light);border-radius:var(--radius);
                                padding:8px 10px;margin-bottom:6px;font-size:.8125rem;">
                <div style="font-weight:500;margin-bottom:2px;">@u.Ubicacion</div>
                <div style="display:flex;gap:12px;color:var(--color-text-secondary);">
                    <span>✓ @u.Disponible disp.</span>
                    <span>⏳ @u.Reservado res.</span>
                </div>
            </div>
        }
    </div>
}
else
{
    <div style="text-align:center;color:var(--color-text-muted);
                    padding:16px;font-size:.875rem;">
        Sin stock en ubicaciones
    </div>
}

<!-- Acciones -->
<div style="margin-top:20px;display:flex;gap:8px;">
    <a href="/Productos/Editar/@Model.Id" class="btn-secondary-app"
       style="flex:1;justify-content:center;">
        <i class="bi bi-pencil"></i> Editar
    </a>
    <a href="/QR?productoId=@Model.Id" class="btn-secondary-app"
       style="justify-content:center;padding:8px 12px;">
        <i class="bi bi-qr-code"></i>
    </a>
</div>
