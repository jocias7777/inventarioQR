@model InventarioQR.ViewModels.ProductoViewModel
@{
    ViewData["Title"] = "Nuevo Producto";
    ViewData["Section"] = "Inventario › Productos";
}

<div class="page-header">
    <div>
        <div class="page-title">Nuevo producto</div>
        <div class="page-subtitle">Completa la información del catálogo</div>
    </div>
    <a href="/Productos" class="btn-secondary-app">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div style="max-width:760px;">
    <form asp-action="Crear" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <!-- Info básica -->
        <div class="card" style="margin-bottom:16px;">
            <div class="card-header"><span class="card-title">Información básica</span></div>
            <div class="card-body">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">

                    <div>
                        <label asp-for="SKU" style="font-size:.8125rem;font-weight:500;
                               display:block;margin-bottom:6px;">SKU *</label>
                        <input asp-for="SKU" class="form-control"
                               placeholder="Ej: PROD-001" style="border-radius:var(--radius);" />
                        <span asp-validation-for="SKU"
                              style="font-size:.75rem;color:var(--color-danger);"></span>
                    </div>

                    <div>
                        <label asp-for="Estado" style="font-size:.8125rem;font-weight:500;
                               display:block;margin-bottom:6px;">Estado</label>
                        <select asp-for="Estado" class="form-select"
                                style="border-radius:var(--radius);">
                            <option value="Activo">Activo</option>
                            <option value="Inactivo">Inactivo</option>
                        </select>
                    </div>

                    <div style="grid-column:1/-1;">
                        <label asp-for="Nombre" style="font-size:.8125rem;font-weight:500;
                               display:block;margin-bottom:6px;">Nombre *</label>
                        <input asp-for="Nombre" class="form-control"
                               placeholder="Nombre descriptivo del producto"
                               style="border-radius:var(--radius);" />
                        <span asp-validation-for="Nombre"
                              style="font-size:.75rem;color:var(--color-danger);"></span>
                    </div>

                    <div>
                        <label asp-for="PrecioBase" style="font-size:.8125rem;font-weight:500;
                               display:block;margin-bottom:6px;">Precio base (Q)</label>
                        <input asp-for="PrecioBase" type="number" step="0.01"
                               class="form-control" placeholder="0.00"
                               style="border-radius:var(--radius);" />
                    </div>

                    <div>
                        <label asp-for="ImagenFile" style="font-size:.8125rem;font-weight:500;
                               display:block;margin-bottom:6px;">Imagen del producto</label>
                        <input asp-for="ImagenFile" type="file"
                               accept=".jpg,.jpeg,.png,.webp"
                               class="form-control"
                               style="border-radius:var(--radius);"
                               onchange="previewImg(this)" />
                        <img id="imgPreview" src="#" alt=""
                             style="display:none;margin-top:8px;height:80px;
                                    object-fit:cover;border-radius:var(--radius);
                                    border:1px solid var(--color-border);" />
                    </div>

                    <div style="grid-column:1/-1;">
                        <label asp-for="Descripcion" style="font-size:.8125rem;font-weight:500;
                               display:block;margin-bottom:6px;">Descripción</label>
                        <textarea asp-for="Descripcion" class="form-control" rows="3"
                                  placeholder="Descripción opcional..."
                                  style="border-radius:var(--radius);resize:vertical;"></textarea>
                    </div>
                </div>
            </div>
        </div>

        <!-- Variantes -->
        <div class="card" style="margin-bottom:16px;">
            <div class="card-header">
                <span class="card-title">Variantes (opcional)</span>
                <button type="button" class="btn-secondary-app"
                        style="padding:5px 12px;font-size:.8125rem;"
                        onclick="agregarVariante()">
                    <i class="bi bi-plus"></i> Agregar
                </button>
            </div>
            <div class="card-body">
                <div id="variantesContainer">
                    <p style="font-size:.875rem;color:var(--color-text-muted);
                               text-align:center;padding:16px 0;">
                        Sin variantes — haz clic en "Agregar" para añadir.
                    </p>
                </div>
            </div>
        </div>

        <!-- Acciones -->
        <div style="display:flex;gap:12px;">
            <button type="submit" class="btn-primary-app">
                <i class="bi bi-check-lg"></i> Guardar producto
            </button>
            <a href="/Productos" class="btn-secondary-app">Cancelar</a>
        </div>

    </form>
</div>

@section Scripts {
    <script>
        let varIdx = 0;

        function agregarVariante() {
            const c = document.getElementById('variantesContainer');
            const p = c.querySelector('p');
            if (p) p.remove();

            const div = document.createElement('div');
            div.style.cssText = 'display:grid;grid-template-columns:1fr 1fr auto;' +
                                'gap:10px;margin-bottom:8px;align-items:end;';
            div.innerHTML = `
                <div>
                    <label style="font-size:.75rem;font-weight:500;
                                  display:block;margin-bottom:4px;">Color</label>
                    <input type="text" name="Variantes[${varIdx}].Color"
                           class="form-control" placeholder="Rojo"
                           style="border-radius:var(--radius);"/>
                </div>
                <div>
                    <label style="font-size:.75rem;font-weight:500;
                                  display:block;margin-bottom:4px;">Talla / Tamaño</label>
                    <input type="text" name="Variantes[${varIdx}].Tamaño"
                           class="form-control" placeholder="M / XL / 42"
                           style="border-radius:var(--radius);"/>
                </div>
                <button type="button" class="btn-icon"
                        onclick="this.parentElement.remove()"
                        style="margin-bottom:0;">
                    <i class="bi bi-trash" style="color:var(--color-danger);"></i>
                </button>`;
            c.appendChild(div);
            varIdx++;
        }

        function previewImg(input) {
            const preview = document.getElementById('imgPreview');
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}