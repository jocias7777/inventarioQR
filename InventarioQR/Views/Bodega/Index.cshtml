@section Scripts {
    <script>
        // ── Árbol colapsable ──
        function toggleArbol(id) {
            const el  = document.getElementById(id);
            const ico = document.getElementById('ico-' + id);
            if (!el) return;

            const isOpen = el.style.display !== 'none';
            el.style.display = isOpen ? 'none' : 'block';

            if (ico) {
                ico.style.transform = isOpen ? '' : 'rotate(90deg)';
            }
        }

        // ── Abrir modales ──
        function abrirModal(id) {
            new bootstrap.Modal(document.getElementById(id)).show();
        }

        function abrirModalZona(bodegaId, bodegaNombre) {
            document.getElementById('nuevaZonaBodegaId').value = bodegaId;
            document.getElementById('labelBodegaZona').textContent = bodegaNombre;
            abrirModal('modalCrearZona');
        }

        function abrirModalEstanteria(zonaId, zonaNombre) {
            document.getElementById('nuevaEstZonaId').value = zonaId;
            document.getElementById('labelZonaEst').textContent = zonaNombre;
            abrirModal('modalCrearEstanteria');
        }

        function abrirModalNivel(estId, estNombre) {
            document.getElementById('nuevoNivEstId').value = estId;
            document.getElementById('labelEstNiv').textContent = estNombre;
            abrirModal('modalCrearNivel');
        }

        function abrirModalPosicion(nivId, nivNombre) {
            document.getElementById('nuevaPosNivId').value = nivId;
            document.getElementById('labelNivPos').textContent = nivNombre;
            abrirModal('modalCrearPosicion');
        }

        // ── Editar bodega (carga datos via AJAX) ──
        async function editarBodega(id) {
            const res  = await fetch(`/Bodega/GetBodega/${id}`);
            const data = await res.json();
            document.getElementById('editBodegaId').value       = data.id;
            document.getElementById('editBodegaNombre').value   = data.nombre;
            document.getElementById('editBodegaUbicacion').value= data.ubicacion ?? '';
            document.getElementById('editBodegaDesc').value     = data.descripcion ?? '';
            abrirModal('modalEditarBodega');
        }

        // ── Editar zona ──
        async function editarZona(id) {
            const res  = await fetch(`/Bodega/GetZona/${id}`);
            const data = await res.json();
            document.getElementById('editZonaId').value      = data.id;
            document.getElementById('editZonaBodegaId').value= data.bodegaId;
            document.getElementById('editZonaNombre').value  = data.nombre;
            abrirModal('modalEditarZona');
        }
    </script>
}