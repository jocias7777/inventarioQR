@model InventarioQR.ViewModels.OperacionDetalleDto

<div style="font-weight:700;margin-bottom:2px;">
    @Model.Tipo #@Model.Id
</div>
<div style="font-size:.8125rem;color:var(--color-text-muted);margin-bottom:12px;">
    @Model.ProductoNombre — @Model.ProductoSKU
</div>

@{
    var (elbl, estadoColor) = Model.Estado switch
    {
        "Pendiente" => ("Pendiente", "var(--color-warning)"),
        "EnProceso" => ("En proceso", "var(--color-info)"),
        "Completada" => ("Completada", "var(--color-success)"),
        _ => (Model.Estado, "var(--color-text-muted)")
    };
}
<div style="margin-bottom:14px;">
    <span style="display:inline-flex;align-items:center;padding:4px 10px;
                 font-size:.75rem;font-weight:600;line-height:1;
                 border:1px solid @estadoColor;background:@estadoColor;
                 color:#fff;border-radius:var(--radius);">
        @elbl
    </span>
    <span style="font-size:.8125rem;color:var(--color-text-secondary);
                 margin-left:8px;">
        @Model.Cantidad unidades
    </span>
</div>

<!-- Ubicaciones -->
@if (!string.IsNullOrEmpty(Model.UbicacionOrigen))
{
    <div style="margin-bottom:8px;">
        <div style="font-size:.6875rem;font-weight:600;text-transform:uppercase;
                        letter-spacing:.08em;color:var(--color-text-muted);
                        margin-bottom:3px;">
            Origen
        </div>
        <div style="font-size:.8125rem;background:var(--color-border-light);
                        border-radius:var(--radius);padding:7px 10px;">
            @Model.UbicacionOrigen
            @if (Model.StockOrigen > 0)
            {
                <span style="margin-left:8px;font-weight:600;
                                     color:var(--color-success);">
                    (@Model.StockOrigen uds)
                </span>
            }
        </div>
    </div>
}
@if (!string.IsNullOrEmpty(Model.UbicacionDestino))
{
    <div style="margin-bottom:12px;">
        <div style="font-size:.6875rem;font-weight:600;text-transform:uppercase;
                        letter-spacing:.08em;color:var(--color-text-muted);
                        margin-bottom:3px;">
            Destino
        </div>
        <div style="font-size:.8125rem;background:var(--color-border-light);
                        border-radius:var(--radius);padding:7px 10px;">
            @Model.UbicacionDestino
        </div>
    </div>
}

<!-- Pasos -->
<div style="margin-bottom:14px;">
    <div style="font-size:.6875rem;font-weight:600;text-transform:uppercase;
                letter-spacing:.08em;color:var(--color-text-muted);
                margin-bottom:8px;">
        Pasos
    </div>
    @foreach (var paso in Model.Pasos)
    {
        <div style="display:flex;align-items:flex-start;gap:8px;
                        margin-bottom:8px;font-size:.8125rem;">
            <div style="width:20px;height:20px;border-radius:50%;flex-shrink:0;
                            display:flex;align-items:center;justify-content:center;
                            font-size:.65rem;font-weight:700;margin-top:1px;
                            background:@(paso.Completado
                                             ? "var(--color-success)"
                                             : "var(--color-border)");
                        color:@(paso.Completado ? "#fff" : "var(--color-text-muted)");">
            @(paso.Completado ? "✓" : paso.Numero.ToString())
        </div>
        <span style="color:@(paso.Completado
                              ? "var(--color-text-muted)"
                              : "var(--color-text-primary)");
                text-decoration:@(paso.Completado ? "line-through" : "none");">
            @paso.Descripcion
        </span>
    </div>
        }
</div>

@if (!string.IsNullOrEmpty(Model.Notas))
{
    <div style="margin-bottom:12px;">
        <div style="font-size:.6875rem;font-weight:600;text-transform:uppercase;
                        letter-spacing:.08em;color:var(--color-text-muted);
                        margin-bottom:4px;">
            Notas
        </div>
        <div style="font-size:.8125rem;color:var(--color-text-secondary);
                        background:var(--color-border-light);border-radius:var(--radius);
                        padding:8px 10px;">
            @Model.Notas
        </div>
    </div>
}

<div style="font-size:.75rem;color:var(--color-text-muted);margin-bottom:12px;">
    Asignado a: <strong>@Model.AsignadoA</strong><br />
    Creado por: @Model.CreadoPor<br />
    @Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
</div>

@if (Model.Estado == "Pendiente")
{
    <form asp-action="Iniciar" asp-controller="Operaciones" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <button type="submit" class="btn-primary-app"
                style="width:100%;justify-content:center;">
            <i class="bi bi-play-fill"></i> Iniciar operación
        </button>
    </form>
}
@if (Model.Estado == "EnProceso")
{
    <button class="btn-primary-app"
            style="width:100%;justify-content:center;
                       background:var(--color-success);"
            onclick="abrirCompletarOp(@Model.Id)">
        <i class="bi bi-check-circle"></i> Completar operación
    </button>
}