@using X.PagedList
@model X.PagedList.IPagedList<InventarioQR.ViewModels.OperacionListaDto>
@{
    ViewData["Title"] = "Operaciones de Bodega";
    ViewData["Section"] = "Operaciones";
    var resumen = ViewBag.Resumen as InventarioQR.ViewModels.OperacionResumenDto;
    var form = ViewBag.Form as InventarioQR.ViewModels.OperacionCrearViewModel;
}

<div class="page-header">
    <div>
        <div class="page-title">Operaciones de Bodega</div>
        <div class="page-subtitle">
            Picking · Traslado · Confirmación
        </div>
    </div>
    <button class="btn-primary-app"
            data-bs-toggle="modal"
            data-bs-target="#modalCrearOp">
        <i class="bi bi-plus-lg"></i> Nueva operación
    </button>
</div>

<!-- Stats -->
@if (resumen != null)
{
    <div class="grid-4" style="margin-bottom:20px;">
        <div class="stat-card kpi-no-hover">
            <div class="stat-icon yellow">
                <i class="bi bi-hourglass-split"></i>
            </div>
            <div>
                <div class="stat-value">@resumen.Pendientes</div>
                <div class="stat-label">Pendientes</div>
            </div>
        </div>
        <div class="stat-card kpi-no-hover">
            <div class="stat-icon blue">
                <i class="bi bi-play-circle"></i>
            </div>
            <div>
                <div class="stat-value">@resumen.EnProceso</div>
                <div class="stat-label">En proceso</div>
            </div>
        </div>
        <div class="stat-card kpi-no-hover">
            <div class="stat-icon green">
                <i class="bi bi-check-circle"></i>
            </div>
            <div>
                <div class="stat-value">@resumen.CompletadasHoy</div>
                <div class="stat-label">Completadas hoy</div>
            </div>
        </div>
        <div class="stat-card kpi-no-hover">
            <div class="stat-icon gray">
                <i class="bi bi-calendar-week"></i>
            </div>
            <div>
                <div class="stat-value">@resumen.TotalSemana</div>
                <div class="stat-label">Esta semana</div>
            </div>
        </div>
    </div>
}

<!-- Filtros -->
<div style="margin-bottom:16px;">
    <form method="get"
          style="display:flex;gap:8px;flex-wrap:wrap;">

            @{
                var tipos = new[]
                {
                        ("","Todos"),("Picking","Picking"),
                        ("Traslado","Traslado"),("Confirmacion","Confirmación")
                        };
                var estados = new[]
                {
                        ("","Todos estados"),("Pendiente","Pendiente"),
                        ("EnProceso","En proceso"),("Completada","Completada")
                        };
            }

            <div style="display:flex;gap:4px;flex-wrap:wrap;">
                @foreach (var (val, lbl) in tipos)
                {
                    var isA = (ViewBag.Tipo as string ?? "") == val;
                    <a href="?tipo=@val&estado=@ViewBag.Estado"
                       class="btn-secondary-app"
                       style="font-size:.8125rem;padding:6px 10px;
                           @(isA ? "background:#0e7490;color:#fff;border-color:#0e7490;" : "")">
                        @lbl
                    </a>
                }
            </div>

            <select name="estado"
                    onchange="this.form.submit()"
                    style="padding:7px 12px;border:1px solid var(--color-border);
                           border-radius:var(--radius);font-size:.875rem;
                           font-family:inherit;background:#fff;">
                @foreach (var (val, lbl) in estados)
                {
                    <option value="@val"
                            selected="@((ViewBag.Estado as string ?? "") == val)">
                        @lbl
                    </option>
                }
            </select>

    </form>
</div>

<!-- Tabla + panel -->
<div style="display:flex;gap:20px;align-items:flex-start;">

    <div class="card" style="flex:1;min-width:0;">
        <div class="table-wrapper">
            @if (!Model.Any())
            {
                <div class="empty-state">
                    <i class="bi bi-clipboard-check"></i>
                    <p>Sin operaciones para mostrar.</p>
                </div>
            }
            else
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Tipo</th>
                            <th>Producto</th>
                            <th>Origen → Destino</th>
                            <th>Cant.</th>
                            <th>Asignado a</th>
                            <th>Estado</th>
                            <th>Fecha</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var op in Model)
                        {
                            <tr class="op-row" style="cursor:pointer;"
                                onclick="verDetalleOp(@op.Id, this)">
                                <td style="font-size:.75rem;
                                                   color:var(--color-text-muted);">
                                    #@op.Id
                                </td>
                                <td>
                                    @{
                                        var tipoColor = op.Tipo switch
                                        {
                                            "Picking" => "var(--color-warning)",
                                            "Traslado" => "var(--color-info)",
                                            "Confirmacion" => "var(--color-success)",
                                            _ => "var(--color-text-muted)"
                                        };
                                    }
                                    <span style="display:inline-flex;align-items:center;padding:4px 10px;
                                                 font-size:.75rem;font-weight:600;line-height:1;
                                                 border:1px solid @tipoColor;background:@tipoColor;
                                                 color:#fff;border-radius:var(--radius);">
                                        @op.Tipo
                                    </span>
                                </td>
                                <td>
                                    <div style="font-weight:500;
                                                        font-size:.875rem;">
                                        @op.ProductoNombre
                                    </div>
                                    <div style="font-size:.75rem;
                                                        font-family:monospace;
                                                        color:var(--color-text-muted);">
                                        @op.ProductoSKU
                                    </div>
                                </td>
                                <td style="font-size:.8125rem;
                                                   color:var(--color-text-secondary);">
                                    @if (!string.IsNullOrEmpty(op.UbicacionOrigen))
                                    {
                                        <span>@op.UbicacionOrigen</span>
                                    }
                                    @if (!string.IsNullOrEmpty(op.UbicacionDestino))
                                    {
                                        <span style="color:var(--color-text-muted);">
                                            → @op.UbicacionDestino
                                        </span>
                                    }
                                </td>
                                <td style="font-weight:700;">
                                    @op.Cantidad
                                </td>
                                <td style="font-size:.8125rem;
                                                   color:var(--color-text-secondary);">
                                    @op.AsignadoA
                                </td>
                                <td>
                                    @{
                                        var (elbl, estadoColor) = op.Estado switch
                                        {
                                            "Pendiente" => ("Pendiente", "var(--color-warning)"),
                                            "EnProceso" => ("En proceso", "var(--color-info)"),
                                            "Completada" => ("Completada", "var(--color-success)"),
                                            _ => (op.Estado, "var(--color-text-muted)")
                                        };
                                    }
                                    <span style="display:inline-flex;align-items:center;padding:4px 10px;
                                                 font-size:.75rem;font-weight:600;line-height:1;
                                                 border:1px solid @estadoColor;background:@estadoColor;
                                                 color:#fff;border-radius:var(--radius);">
                                        @elbl
                                    </span>
                                </td>
                                <td style="font-size:.75rem;
                                                   color:var(--color-text-muted);
                                                   white-space:nowrap;">
                                    @op.FechaCreacion.ToString("dd/MM HH:mm")
                                </td>
                                <td onclick="event.stopPropagation()">
                                    <div style="display:flex;gap:3px;">
                                        @if (op.Estado == "Pendiente")
                                        {
                                            <form asp-action="Iniciar"
                                                  method="post"
                                                  style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id"
                                                       value="@op.Id" />
                                                <button type="submit"
                                                        class="btn-icon"
                                                        title="Iniciar"
                                                        style="width:28px;height:28px;">
                                                    <i class="bi bi-play-fill"
                                                       style="color:var(--color-accent);
                                                                          font-size:.75rem;"></i>
                                                </button>
                                            </form>
                                        }
                                        @if (op.Estado == "EnProceso")
                                        {
                                            <button class="btn-icon"
                                                    style="width:28px;height:28px;"
                                                    title="Completar"
                                                    onclick="abrirCompletarOp(
                                                                    @op.Id)">
                                                <i class="bi bi-check-lg"
                                                   style="color:var(--color-success);
                                                                      font-size:.75rem;"></i>
                                            </button>
                                        }
                                        @if (op.Estado != "Completada")
                                        {
                                            <form asp-action="Cancelar"
                                                  method="post"
                                                  style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id"
                                                       value="@op.Id" />
                                                <button type="submit"
                                                        class="btn-icon"
                                                        style="width:28px;height:28px;"
                                                        title="Cancelar"
                                                        onclick="return confirm('¿Cancelar operación #@op.Id?')">
                                                    <i class="bi bi-x-lg"
                                                       style="color:var(--color-danger);
                                                                          font-size:.7rem;"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (Model.PageCount > 1)
                {
                    <div style="display:flex;align-items:center;
                                        justify-content:space-between;
                                        padding:12px 16px;
                                        border-top:1px solid var(--color-border);">
                        <span style="font-size:.8125rem;
                                             color:var(--color-text-muted);">
                            Página @Model.PageNumber de @Model.PageCount
                        </span>
                        <div style="display:flex;gap:4px;">
                            @if (Model.HasPreviousPage)
                            {
                                <a href="?pagina=@(Model.PageNumber - 1)&tipo=@ViewBag.Tipo&estado=@ViewBag.Estado"
                                   class="btn-secondary-app"
                                   style="padding:5px 10px;">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            }
                            @if (Model.HasNextPage)
                            {
                                <a href="?pagina=@(Model.PageNumber + 1)&tipo=@ViewBag.Tipo&estado=@ViewBag.Estado"
                                   class="btn-secondary-app"
                                   style="padding:5px 10px;">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Panel lateral -->
    <div id="panelOp"
         style="width:300px;flex-shrink:0;display:none;">
        <div class="card">
            <div style="padding:14px 16px;
                        border-bottom:1px solid var(--color-border);
                        display:flex;align-items:center;
                        justify-content:space-between;">
                <span style="font-weight:600;font-size:.9375rem;">
                    Detalle operación
                </span>
                <button class="btn-icon" onclick="cerrarPanelOp()">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div id="panelOpBody" style="padding:16px;"></div>
        </div>
    </div>

</div>

<!-- MODAL: Crear operación -->
<div class="modal fade" id="modalCrearOp" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered"
         style="margin-top:60px;max-width:520px;">
        <div class="modal-content"
             style="border-radius:var(--radius);
                    border:1px solid var(--color-border);">
            <div class="modal-header"
                 style="border-bottom:1px solid var(--color-border);
                        padding:16px 20px;">
                <h6 class="modal-title fw-bold">
                    <i></i>
                    Nueva operación de bodega
                </h6>
                <button type="button" class="btn-close btn-close-sm"
                        data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Crear" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body" style="padding:20px;">

                    <!-- Tipo -->
                    <div class="mb-3">
                        <label class="form-label"
                               style="font-size:.8125rem;font-weight:500;">
                            Tipo de operación
                        </label>
                        <div style="display:grid;
                                    grid-template-columns:repeat(3,1fr);
                                    gap:8px;">
                            @{
                                var opTipos = new[]
                                {
                                                        ("Picking","bi-hand-index",
                                                        "var(--color-warning)","Picking"),
                                                        ("Traslado","bi-arrows-move",
                                                        "var(--color-accent)","Traslado"),
                                                        ("Confirmacion","bi-patch-check",
                                                        "var(--color-success)","Confirmación")
                                                        };
                            }
                            @foreach (var (tv, ti, tc, tl) in opTipos)
                            {
                                <label style="cursor:pointer;text-align:center;">
                                    <input type="radio" name="Tipo"
                                           value="@tv"
                                           style="display:none;"
                                           onchange="onOpTipoChange('@tv','@tc')"
                                           @(tv == "Picking" ? "checked" : "") />
                                    <div id="opTipo_@tv"
                                         style="padding:10px 6px;
                                                    border:2px solid @(tv == "Picking" ? tc : "var(--color-border)");
                                                    background:@(tv == "Picking" ? "var(--color-warning-light)" : "");
                                                    border-radius:var(--radius);
                                                    transition:.15s;">
                                        <i class="bi @ti"
                                           style="font-size:1.125rem;
                                                      color:@tc;display:block;
                                                      margin-bottom:4px;"></i>
                                        <span style="font-size:.75rem;
                                                         font-weight:500;">
                                            @tl
                                        </span>
                                    </div>
                                </label>
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"
                               style="font-size:.8125rem;font-weight:500;">
                            Producto *
                        </label>
                        <select name="ProductoId" required
                                class="form-select"
                                style="border-radius:var(--radius);
                                       font-size:.875rem;">
                            <option value="">— Selecciona —</option>
                            @if (form != null)
                            {
                                @foreach (var p in form.Productos)
                                {
                                    <option value="@p.Id">@p.Texto</option>
                                }
                            }
                        </select>
                    </div>

                    <div style="display:grid;
                                grid-template-columns:1fr 1fr;
                                gap:12px;margin-bottom:12px;">
                        <div>
                            <label class="form-label"
                                   style="font-size:.8125rem;font-weight:500;">
                                Posición origen
                            </label>
                            <select name="PosicionOrigenId"
                                    id="opOrigen"
                                    class="form-select"
                                    style="border-radius:var(--radius);
                                           font-size:.8125rem;">
                                <option value="">— Sin origen —</option>
                                @if (form != null)
                                {
                                    @foreach (var p in form.Posiciones)
                                    {
                                        <option value="@p.Id">@p.Texto</option>
                                    }
                                }
                            </select>
                        </div>
                        <div>
                            <label class="form-label"
                                   style="font-size:.8125rem;font-weight:500;">
                                Posición destino
                            </label>
                            <select name="PosicionDestinoId"
                                    id="opDestino"
                                    class="form-select"
                                    style="border-radius:var(--radius);
                                           font-size:.8125rem;">
                                <option value="">— Sin destino —</option>
                                @if (form != null)
                                {
                                    @foreach (var p in form.Posiciones)
                                    {
                                        <option value="@p.Id">@p.Texto</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div style="display:grid;
                                grid-template-columns:1fr 1fr;
                                gap:12px;margin-bottom:12px;">
                        <div>
                            <label class="form-label"
                                   style="font-size:.8125rem;font-weight:500;">
                                Cantidad *
                            </label>
                            <input type="number" name="Cantidad"
                                   min="1" required
                                   class="form-control"
                                   style="border-radius:var(--radius);
                                          font-size:1.125rem;font-weight:700;
                                          text-align:center;"
                                   placeholder="0" />
                        </div>
                        <div>
                            <label class="form-label"
                                   style="font-size:.8125rem;font-weight:500;">
                                Asignar a
                            </label>
                            <select name="AsignadoA"
                                    class="form-select"
                                    style="border-radius:var(--radius);
                                           font-size:.875rem;">
                                <option value="">— Yo mismo —</option>
                                @if (form != null)
                                {
                                    @foreach (var u in form.Usuarios)
                                    {
                                        <option value="@u.Nombre">
                                            @u.Nombre
                                        </option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div>
                        <label class="form-label"
                               style="font-size:.8125rem;font-weight:500;">
                            Notas
                        </label>
                        <textarea name="Notas" class="form-control"
                                  rows="2"
                                  style="border-radius:var(--radius);
                                         resize:none;"
                                  placeholder="Instrucciones adicionales...">
                        </textarea>
                    </div>

                </div>
                <div class="modal-footer"
                     style="border-top:1px solid var(--color-border);
                            padding:12px 20px;">
                    <button type="button" class="btn-secondary-app"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit" class="btn-primary-app">
                        <i class="bi bi-check-lg"></i> Crear operación
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL: Completar con QR -->
<div class="modal fade" id="modalCompletarOp"
     tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered"
         style="margin-top:60px;max-width:420px;">
        <div class="modal-content"
             style="border-radius:var(--radius);
                    border:1px solid var(--color-border);">
            <div class="modal-header"
                 style="border-bottom:1px solid var(--color-border);
                        padding:16px 20px;">
                <h6 class="modal-title fw-bold">
                    <i class="bi bi-qr-code-scan me-2"
                       style="color:var(--color-success);"></i>
                    Confirmar operación
                </h6>
                <button type="button" class="btn-close btn-close-sm"
                        data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Completar" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="completarOpId" />
                <div class="modal-body" style="padding:20px;">
                    <div class="alert-app"
                         style="background:var(--color-success-light);
                                border-left:3px solid var(--color-success);
                                color:#166534;margin-bottom:16px;">
                        <i class="bi bi-info-circle-fill"></i>
                        <span style="font-size:.875rem;">
                            Escanea el QR de la ubicación para
                            confirmar, o deja vacío para completar
                            sin validación.
                        </span>
                    </div>
                    <label class="form-label"
                           style="font-size:.8125rem;font-weight:500;">
                        Payload QR (opcional)
                    </label>
                    <input type="text" name="payloadQR"
                           id="completarPayload"
                           class="form-control"
                           style="border-radius:var(--radius);
                                  font-family:monospace;"
                           placeholder="Escanea o pega el QR..." />
                </div>
                <div class="modal-footer"
                     style="border-top:1px solid var(--color-border);
                            padding:12px 20px;">
                    <button type="button" class="btn-secondary-app"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit" class="btn-primary-app">
                        <i class="bi bi-check-circle"></i>
                        Confirmar y completar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function verDetalleOp(id, row) {
            document.querySelectorAll('.op-row')
                .forEach(r => r.style.background = '');
            row.style.background = 'var(--color-accent-light)';
            document.getElementById('panelOp').style.display = 'block';
            document.getElementById('panelOpBody').innerHTML =
                '<div style="text-align:center;padding:32px;color:var(--color-text-muted);">' +
                '<div class="spinner-border spinner-border-sm"></div></div>';

            const res  = await fetch(`/Operaciones/Detalle/${id}`);
            const html = await res.text();
            document.getElementById('panelOpBody').innerHTML = html;
        }

        function cerrarPanelOp() {
            document.getElementById('panelOp').style.display = 'none';
            document.querySelectorAll('.op-row')
                .forEach(r => r.style.background = '');
        }

        function abrirCompletarOp(id) {
            document.getElementById('completarOpId').value   = id;
            document.getElementById('completarPayload').value= '';
            new bootstrap.Modal(
                document.getElementById('modalCompletarOp')).show();
        }

        function onOpTipoChange(tipo, color) {
            ['Picking','Traslado','Confirmacion'].forEach(t => {
                const el = document.getElementById('opTipo_' + t);
                if (el) {
                    el.style.borderColor = 'var(--color-border)';
                    el.style.background  = '';
                }
            });
            const el = document.getElementById('opTipo_' + tipo);
            if (el) {
                el.style.borderColor = color;
                el.style.background  =
                    tipo === 'Picking'      ? 'var(--color-warning-light)' :
                    tipo === 'Traslado'     ? 'var(--color-accent-light)'  :
                                              'var(--color-success-light)';
            }
        }
    </script>
}
