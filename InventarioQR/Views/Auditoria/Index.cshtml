@using X.PagedList
@model X.PagedList.IPagedList<InventarioQR.ViewModels.AuditoriaListaDto>
@{
    ViewData["Title"] = "Auditoría";
    ViewData["Section"] = "Reportes";
    var resumen = ViewBag.Resumen as InventarioQR.ViewModels.AuditoriaResumenDto;
    var modulos = ViewBag.Modulos as List<string> ?? new();
    var acciones = ViewBag.Acciones as List<string> ?? new();
}

<div class="page-header">
    <div>
        <div class="page-title">Auditoría del sistema</div>
        <div class="page-subtitle">
            Trazabilidad total — @Model.TotalItemCount registros
        </div>
    </div>
    <a href="/Auditoria/ExportarCSV" class="btn-secondary-app">
        <i class="bi bi-download"></i> Exportar CSV
    </a>
</div>

